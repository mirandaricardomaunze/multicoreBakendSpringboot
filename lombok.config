# Lombok project-wide config
# Documentação: https://projectlombok.org/features/configuration

# Parar de procurar configs em pastas pai (este é a raíz do projecto)
config.stopBubbling = true

# Marca métodos/classes gerados com @lombok.Generated — útil para cobertura de testes
lombok.addLombokGeneratedAnnotation = true

# Não gerar @ConstructorProperties (não usamos serialização XML que precise disto)
lombok.anyConstructor.addConstructorProperties = false

# Proibir @Data em entidades JPA (gera equals/hashCode que partem proxies do Hibernate)
# Ver CONVENTIONS.md §3.
lombok.data.flagUsage = ERROR

# Proibir @AllArgsConstructor e @Builder em entidades — preferir construtor explícito.
lombok.allArgsConstructor.flagUsage = WARNING
lombok.builder.flagUsage = WARNING

# @Autowired em campos é proibido pela convenção (injecção por construtor).
# Lombok não detecta @Autowired, mas mantemos esta convenção via code review.
